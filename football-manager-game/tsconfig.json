{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "tests",
    "node_modules"
  ]
}
